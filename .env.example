# 72Hours 环境变量配置

# SiliconFlow API 配置（必需）
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# 默认使用的模型（可选，默认为 MiniMax-M2.1）
DEFAULT_MODEL=Pro/MiniMaxAI/MiniMax-M2.1
# 可选：deepseek-ai/DeepSeek-V3.2

# 服务器端口（可选，默认为 3000）
PORT=3000

# Node 环境
NODE_ENV=production

# CORS 配置（可选，生产环境建议设置具体域名）
# CORS_ORIGIN=https://yourdomain.com
